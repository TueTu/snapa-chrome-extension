{
  "manifest_version": 3,
  "name": "Snapa Chat",
  "version": "1.0",
  "description": "A simple AI chat extension powered by the user's API key",
  "action": {
    "default_popup": "index.html",
    "default_title": "Snapa Chat",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "permissions": ["activeTab", "contextMenus", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
